{
  "claude.codespaces.enabled": true,
  "claude.hooks.autoRun": true,
  "claude.hooks.defaultWorkflow": [
    "beforeEach",
    "afterEach",
    "afterAll"
  ],
  "claude.hooks.reportPath": "artifacts/automation-report.md",
  "claude.hooks.commands": {
    "beforeEach": "python scripts/run_automation.py",
    "afterEach": "python .claude/hooks/reporting/report-generator.py",
    "afterAll": "python .claude/hooks/reporting/report-generator.py"
  }
}
